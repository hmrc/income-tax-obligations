# microservice specific routes

GET        /:nino/open-obligations                                   uk.gov.hmrc.incometaxobligations.controllers.ObligationsController.getOpenObligations(nino)
GET        /:nino/obligations/from/:from/to/:to                      uk.gov.hmrc.incometaxobligations.controllers.ObligationsController.getAllObligations(nino, from, to)
GET        /:nino/fulfilled-obligations                              uk.gov.hmrc.incometaxobligations.controllers.ObligationsController.getFulfilledObligations(nino)

GET         /itsa-status/status/:nino/:year                          uk.gov.hmrc.incometaxobligations.controllers.ITSAStatusController.getITSAStatus(nino,year,futureYears:Boolean,history:Boolean)
PUT         /itsa-status/update/:nino                                uk.gov.hmrc.incometaxobligations.controllers.ITSAStatusController.updateItsaStatus(nino)